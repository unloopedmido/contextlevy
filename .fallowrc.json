{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/index.ts", "src/cli/index.ts"],
  "ignorePatterns": ["dist/**", "lib/**", "examples/**"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@actions/core",
    "@actions/github",
    "@octokit/auth-app",
    "@octokit/rest",
    "@vercel/ncc"
  ],
  "rules": {
    "unused-files": "error",
    "unused-exports": "error",
    "unused-types": "warn",
    "duplicate-exports": "error",
    "unresolved-imports": "error",
    "circular-dependency": "warn"
  },
  "duplicates": {
    "threshold": 5,
    "minLines": 18,
    "ignore": ["tests/**"]
  },
  "health": {
    "ignore": ["examples/**"],
    "maxCyclomatic": 22,
    "maxCognitive": 18
  },
  "overrides": [
    {
      "files": ["tests/**"],
      "rules": {
        "unused-exports": "off",
        "unused-types": "off"
      }
    }
  ]
}
