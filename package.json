{
  "name": "contextlevy",
  "version": "2.4.0",
  "description": "Repo hygiene linter for agent-heavy teams — local CLI and GitHub Action",
  "license": "MIT",
  "author": "nonlooped",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonlooped/contextlevy.git"
  },
  "homepage": "https://github.com/nonlooped/contextlevy#readme",
  "bugs": {
    "url": "https://github.com/nonlooped/contextlevy/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "context",
    "cursor",
    "diff",
    "github-actions",
    "llm",
    "tokens"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "lib/cli/index.js",
  "bin": {
    "contextlevy": "bin/contextlevy.js"
  },
  "files": [
    "bin",
    "lib",
    "docs/CLI.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:action && npm run build:cli",
    "build:action": "ncc build src/index.ts -o dist --license licenses.txt",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepack": "npm run build:cli",
    "pack:check": "npm pack --dry-run",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "check:biome": "biome ci .",
    "check": "npm run check:biome && npm run typecheck && npm test && npm run check:fallow",
    "check:fallow": "npm run build:cli && fallow dead-code",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "all": "npm run check && npm run build"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "js-tiktoken": "^1.0.21",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^6.0.1",
    "@biomejs/biome": "2.4.15",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/rest": "^21.1.1",
    "@types/node": "^25.9.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.7",
    "fallow": "^2.80.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "undici": "^6.25.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
