{
  "name": "contextlevy",
  "version": "2.1.0",
  "description": "GitHub Action: estimate AI agent context overhead from PR diffs",
  "license": "MIT",
  "private": true,
  "main": "dist/index.js",
  "bin": {
    "contextlevy": "./bin/contextlevy.js"
  },
  "files": [
    "action.yml",
    "bin",
    "dist",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "ncc build src/index.ts -o dist --license licenses.txt && tsc -p tsconfig.cli.json",
    "build:action": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@octokit/auth-app": "^7.1.5",
    "@octokit/rest": "^21.1.1",
    "js-tiktoken": "^1.0.21",
    "yaml": "^2.8.0"
  },
  "overrides": {
    "undici": "^6.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
